#!/usr/bin/env node

/**
 * pattern-runner — Pattern-First AI CLI
 *
 * A thin CLI layer over pattern execution. Supports:
 *   - Product research: --keyword + --location
 *   - Knowledge Q&A:   --question + (optional) --knowledge-dir
 *   - Provider abstraction for pluggable backends
 *   - Session memory for run history
 */

'use strict';

const fs = require('fs');
const path = require('path');

// ─── Lib modules ───────────────────────────────────────────────────────────

const { parseArgs, USAGE } = require('./lib/cli');
const { loadPattern, findPattern } = require('./lib/pattern-loader');
const { generateProducts } = require('./lib/seed-data');
const { getProvider, listProviders } = require('./lib/provider');
const { recordRun, getHistory, getAllHistory, clearMemory } = require('./lib/memory');
const { formatReport, formatJson, formatVerbose, formatMemory, formatKnowledgeAnswer } = require('./lib/formatter');

// ─── Main ──────────────────────────────────────────────────────────────────

function main() {
  const args = parseArgs(process.argv.slice(2));

  if (args.help) {
    console.log(USAGE);
    process.exit(0);
  }

  if (args.listPatterns) {
    listPatterns();
    process.exit(0);
  }

  if (args.listProviders) {
    listAvailableProviders();
    process.exit(0);
  }

  if (args.clearMemory) {
    clearMemory();
    console.log('Session memory cleared.');
    process.exit(0);
  }

  // Memory view mode
  if (args.memory) {
    if (args.keyword) {
      const h = getHistory(args.keyword, args.location);
      if (!h) {
        console.log(`No history for "${args.keyword}" in "${args.location}".`);
        process.exit(0);
      }
      console.log(formatMemory(h, args));
    } else {
      const all = getAllHistory();
      if (all.length === 0) {
        console.log('No run history yet. Run a pattern first.');
        process.exit(0);
      }
      for (const h of all) {
        console.log(`${h.keyword} (${h.location}) — ${h.runCount} runs, ${h.totalPassed} passed, ${h.totalFailed} failed`);
      }
    }
    process.exit(0);
  }

  // ─── Knowledge Q&A Mode ──────────────────────────────────────────────
  if (args.question) {
    runKnowledgeMode(args);
    return;  // exit inside runKnowledgeMode
  }

  // ─── Product Research Mode ───────────────────────────────────────────
  if (!args.keyword) {
    console.error('Error: --keyword (research) or --question (knowledge) is required.\n');
    console.log(USAGE);
    process.exit(1);
  }

  // Load pattern
  const patternPath = args.pattern
    ? findPattern(args.pattern)
    : path.join(__dirname, 'pattern-schema-test-results.json');

  let pattern;
  try {
    pattern = loadPattern(patternPath);
  } catch (err) {
    console.error(`Error loading pattern: ${err.message}`);
    process.exit(1);
  }

  // Select provider
  const provider = getProvider(args.provider);

  // Generate product data
  const location = args.location || 'US';
  const products = generateProducts(args.keyword, location, { count: 10 });

  // Run checks via provider
  const results = provider.runChecks(products, pattern);

  // Record run in session memory
  recordRun({
    keyword: args.keyword,
    location: location,
    pattern: pattern.name || 'Unnamed',
    provider: provider.id,
    summary: results.summary,
    args,
  });

  // Output
  if (args.format === 'json') {
    console.log(formatJson(results, args, provider));
  } else if (args.verbose) {
    console.log(formatVerbose(results, args, pattern, provider));
  } else {
    console.log(formatReport(results, args, pattern, provider));
  }

  process.exit(results.passed.length > 0 ? 0 : 1);
}

// ─── Knowledge Mode ────────────────────────────────────────────────────────

function runKnowledgeMode(args) {
  const knowledgeDir = args.knowledgeDir
    ? path.resolve(args.knowledgeDir)
    : path.join(__dirname, '.knowledge', 'techcorp');

  // Load pattern (knowledge or default)
  const patternPath = args.pattern
    ? findPattern(args.pattern)
    : path.join(__dirname, 'patterns', 'techcorp-knowledge-assistant.json');

  let pattern;
  try {
    if (fs.existsSync(patternPath)) {
      pattern = loadPattern(patternPath);
    }
  } catch (err) {
    // No pattern file — still run with defaults
  }

  // Use knowledge provider
  const provider = getProvider('techcorp-knowledge');

  // Answer the question
  try {
    const answer = provider.answerQuestion(args.question, knowledgeDir);
    const validation = provider.validateAnswer(args.question, answer, knowledgeDir);

    if (args.format === 'json') {
      console.log(JSON.stringify({ answer, validation, pattern: pattern?.name || 'TechCorpKnowledgeAssistant' }, null, 2));
    } else {
      console.log(formatKnowledgeAnswer(args.question, answer, validation, provider));
    }

    process.exit(validation.passed ? 0 : 1);
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
}

// ─── Utilities ─────────────────────────────────────────────────────────────

function listPatterns() {
  // Check both root and patterns/ directory
  const patternsDir = path.join(__dirname, 'patterns');
  const files = [];

  if (fs.existsSync(patternsDir)) {
    const dirFiles = fs.readdirSync(patternsDir).filter(f => f.endsWith('.json'));
    files.push(...dirFiles.map(f => `  ${f.replace('.json', '')}    (patterns/)`));
  }

  // Root patterns
  if (fs.existsSync(path.join(__dirname, 'pattern-schema-test-results.json'))) {
    files.push('  mvp-research     (root)');
  }

  if (files.length === 0) {
    console.log('No pattern files found.');
    return;
  }

  console.log('Available patterns:');
  for (const f of files) {
    console.log(f);
  }
}

function listAvailableProviders() {
  const providers = listProviders();
  console.log('Available execution providers:');
  for (const p of providers) {
    console.log(`  ${p.id} — ${p.name}`);
    console.log(`    ${p.description}`);
    console.log(`    Type: ${p.type}, Capabilities: ${(p.capabilities || []).join(', ')}`);
    console.log('');
  }
}

main();
